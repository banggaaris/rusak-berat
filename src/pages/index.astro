---
import "../styles/global.css";
import AuthSection from "../components/AuthSection.astro";
import UploadTab from "../components/UploadTab.astro";
import UploadHentiGunaTab from "../components/UploadHentiGunaTab.astro";
import DeleteTab from "../components/DeleteTab.astro";
import ValidasiTab from "../components/ValidasiTab.astro";
import ApproveTab from "../components/ApproveTab.astro";
import Dashboard from "../components/Dashboard.astro";
---

<!doctype html>
<html lang="id">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>SAKTI Bulk Tool - Pengembangan Aset</title>
        <script
            src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"
            is:inline></script>
    </head>
    <body>
        <div class="container">
            <header>
                <h1>🚀 SAKTI Bulk Tool</h1>
                <p class="subtitle">Pengembangan Aset Tetap</p>
            </header>

            <!-- Tabs -->
            <div class="tabs">
                <button class="tab active" data-tab="upload"
                    >📤 Rusak-Berat</button
                >
                <button class="tab" data-tab="hentiGuna">📤 Henti-Guna</button>
                <button class="tab" data-tab="delete">🗑️ Delete</button>
                <button class="tab" data-tab="validasi">✅ Validasi</button>
                <button class="tab" data-tab="approve">👍 Approve</button>
            </div>

            <!-- Auth Section -->
            <AuthSection />

            <!-- Tab Contents -->
            <UploadTab />
            <UploadHentiGunaTab />
            <DeleteTab />
            <ValidasiTab />
            <ApproveTab />

            <!-- Dashboard -->
            <Dashboard />

            <footer>
                <p>
                    ⚠️ Pastikan Anda sudah login di SAKTI sebelum menggunakan
                    tool ini
                </p>
            </footer>
        </div>

        <script src="/scripts/app.js" is:inline></script>
    </body>
</html>
