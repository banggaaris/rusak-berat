---
// Auth Section Component
---

<section class="card auth-section">
    <h2>🔐 Autentikasi</h2>
    <div class="form-group">
        <label for="sessionId">SAKTI_SESSION_ID</label>
        <input
            type="text"
            id="sessionId"
            placeholder="Paste session ID dari browser..."
        />
    </div>
    <div class="form-group">
        <label for="tokenId">SAKTI_TOKEN_ID</label>
        <input
            type="text"
            id="tokenId"
            placeholder="Paste token ID dari browser..."
        />
    </div>
    <div class="form-group">
        <label for="timestamp">SAKTI_TIMESTAMP</label>
        <div class="input-with-btn">
            <input
                type="text"
                id="timestamp"
                placeholder="Timestamp akan digenerate otomatis"
            />
            <button type="button" id="generateTimestamp" class="btn-secondary"
                >Generate</button
            >
        </div>
    </div>
</section>
