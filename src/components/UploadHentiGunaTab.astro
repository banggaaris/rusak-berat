---
// Upload Henti-Guna Tab Component
---

<div id="hentiGunaTab" class="tab-content">
    <section class="card upload-section">
        <h2>📁 Upload Excel - Henti Guna</h2>
        <p class="info-text">
            Format Excel: <code>noSPPA</code>, <code>kodeUakpb</code>, <code
                >kodeBarang</code
            >, <code>namaBarang</code>, <code>noAwal</code>, <code>noAkhir</code
            >, <code>tglPerolehan</code>
        </p>
        <div class="upload-area" id="hentiGunaUploadArea">
            <input
                type="file"
                id="hentiGunaFileInput"
                accept=".xlsx,.xls"
                hidden
            />
            <div class="upload-icon">📤</div>
            <p>
                Drag & drop file Excel atau <span class="link"
                    >klik untuk memilih</span>
            </p>
            <p class="file-name" id="hentiGunaFileName"></p>
        </div>
    </section>

    <section
        class="card preview-section"
        id="hentiGunaPreviewSection"
        style="display: none;"
    >
        <h2>📋 Preview Data (<span id="hentiGunaDataCount">0</span> baris)</h2>
        <div class="table-container">
            <table id="hentiGunaPreviewTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>noSPPA</th>
                        <th>kodeUakpb</th>
                        <th>kodeBarang</th>
                        <th>namaBarang</th>
                        <th>noAwal</th>
                        <th>noAkhir</th>
                        <th>tglPerolehan</th>
                    </tr>
                </thead>
                <tbody id="hentiGunaPreviewBody"></tbody>
            </table>
        </div>
        <button type="button" id="startHentiGunaUpload" class="btn-primary">
            🚀 Mulai Upload Henti Guna
        </button>
    </section>
</div>
