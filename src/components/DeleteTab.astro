---
// Delete Tab Component
---

<div id="deleteTab" class="tab-content">
    <section class="card upload-section">
        <h2>📁 Upload Excel - Delete</h2>
        <p class="info-text">
            Format Excel: <code>object</code> (ID object yang akan dihapus)
        </p>
        <div class="upload-area" id="deleteUploadArea">
            <input
                type="file"
                id="deleteFileInput"
                accept=".xlsx,.xls"
                hidden
            />
            <div class="upload-icon">🗑️</div>
            <p>
                Drag & drop file Excel atau <span class="link"
                    >klik untuk memilih</span>
            </p>
            <p class="file-name" id="deleteFileName"></p>
        </div>
    </section>

    <section
        class="card preview-section"
        id="deletePreviewSection"
        style="display: none;"
    >
        <h2>📋 Preview Data (<span id="deleteDataCount">0</span> baris)</h2>
        <div class="table-container">
            <table id="deletePreviewTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>object</th>
                    </tr>
                </thead>
                <tbody id="deletePreviewBody"></tbody>
            </table>
        </div>
        <button type="button" id="startDelete" class="btn-danger">
            🗑️ Mulai Delete
        </button>
    </section>
</div>
