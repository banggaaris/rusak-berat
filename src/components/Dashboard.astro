---
// Dashboard Component
---

<section
    class="card dashboard-section"
    id="dashboardSection"
    style="display: none;"
>
    <h2>📊 Dashboard Progress</h2>
    <div class="progress-summary">
        <div class="stat-box">
            <span class="stat-label">Total</span>
            <span class="stat-value" id="statTotal">0</span>
        </div>
        <div class="stat-box success">
            <span class="stat-label">Sukses</span>
            <span class="stat-value" id="statSuccess">0</span>
        </div>
        <div class="stat-box error">
            <span class="stat-label">Gagal</span>
            <span class="stat-value" id="statError">0</span>
        </div>
        <div class="stat-box pending">
            <span class="stat-label">Pending</span>
            <span class="stat-value" id="statPending">0</span>
        </div>
    </div>
    <div class="progress-bar-container">
        <div class="progress-bar" id="progressBar"></div>
    </div>
    <p class="progress-text"><span id="progressPercent">0</span>% selesai</p>

    <div class="log-container" id="logContainer"></div>
</section>
